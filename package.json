{
  "name": "react-native-image-collage",
  "version": "0.2.1",
  "description": "Facebook/Instagram-style responsive image collage layouts for React Native and Expo — multi-image grids, +N overflow badge, optional full-screen viewer",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./viewer": {
      "react-native": "./src/viewer/index.ts",
      "types": "./dist/viewer/index.d.ts",
      "default": "./dist/viewer/index.js"
    },
    "./expo": {
      "react-native": "./src/expo/index.tsx",
      "types": "./dist/expo/index.d.ts",
      "default": "./dist/expo/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "example": "npm run build && npm install --prefix example && npm run start --prefix example -- --clear"
  },
  "keywords": [
    "react-native",
    "react-native-collage",
    "image-collage",
    "photo-collage",
    "image-grid",
    "photo-grid",
    "image-layout",
    "multi-image",
    "image-gallery",
    "photo-gallery",
    "gallery",
    "image-viewer",
    "lightbox",
    "mosaic",
    "facebook-layout",
    "instagram-layout",
    "social-feed",
    "feed-layout",
    "expo",
    "react-native-component",
    "typescript",
    "mobile",
    "ios",
    "android",
    "ui",
    "layout",
    "responsive",
    "collage"
  ],
  "author": "Faisal Khawaj",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FaisalKhawaj/react-native-image-collage.git"
  },
  "bugs": {
    "url": "https://github.com/FaisalKhawaj/react-native-image-collage/issues"
  },
  "homepage": "https://github.com/FaisalKhawaj/react-native-image-collage#readme",
  "peerDependencies": {
    "expo-image": ">=1.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-image-viewing": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "expo-image": {
      "optional": true
    },
    "react-native-image-viewing": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "expo-image": "^3.0.10",
    "react": "^19.0.0",
    "react-native": "^0.81.0",
    "react-native-image-viewing": "^0.2.2",
    "typescript": "^5.8.0"
  }
}
